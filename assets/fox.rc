// Ressources Windows pour Fox Browser
// Embarqué dans l'exe via windres

#include <winver.h>

// Icône principale
IDI_ICON1 ICON "icons/fox.ico"

// Métadonnées version
VS_VERSION_INFO VERSIONINFO
FILEVERSION     0,3,0,0
PRODUCTVERSION  0,3,0,0
FILEFLAGSMASK   VS_FFI_FILEFLAGSMASK
FILEFLAGS       0
FILEOS          VOS_NT_WINDOWS32
FILETYPE        VFT_APP
FILESUBTYPE     VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName",      "Fox Browser Project\0"
            VALUE "FileDescription",  "Fox Browser — Navigateur souverain\0"
            VALUE "FileVersion",      "0.3.0\0"
            VALUE "InternalName",     "fox-gui\0"
            VALUE "LegalCopyright",   "Licence MIT\0"
            VALUE "OriginalFilename", "fox-gui.exe\0"
            VALUE "ProductName",      "Fox Browser\0"
            VALUE "ProductVersion",   "0.3.0\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 0x04B0
    END
END
